
# Active Directory Configuration
AD_URL=ldap://your-domain-controller.company.com:389
AD_BIND_DN=CN=service-account,OU=Service Accounts,DC=company,DC=com
AD_BIND_PASSWORD=your-service-account-password
AD_SEARCH_BASE=OU=Users,DC=company,DC=com
AD_SEARCH_FILTER=(sAMAccountName={{username}})

# AD Group Mappings (optional - can be configured in ad-service.ts)
AD_ADMIN_GROUPS=CN=ITSM-Admins,OU=Groups,DC=company,DC=com
AD_MANAGER_GROUPS=CN=ITSM-Managers,OU=Groups,DC=company,DC=com
AD_TECH_GROUPS=CN=ITSM-Technicians,OU=Groups,DC=company,DC=com;CN=IT-Support,OU=Groups,DC=company,DC=com
